generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Mill {
  id            Int      @id @default(autoincrement())
  name          String
  code          String   @unique
  address       String?
  contactPerson String?  @map("contact_person")
  email         String?
  phone         String?
  contactNo     String?
  gstin         String?  @unique
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  YarnLot YarnLot[]

  @@map("mills")
}

model Knitter {
  id            Int      @id @default(autoincrement())
  name          String
  code          String   @unique
  address       String?
  contactPerson String?  @map("contact_person")
  email         String?
  phone         String?
  contactNo     String?
  gstin         String?  @unique
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  KnitterStock   KnitterStock[]
  DeliveryNote   DeliveryNote[]
  KnitterProgram KnitterProgram[]

  @@map("knitters")
}

model Dyer {
  id            Int      @id @default(autoincrement())
  name          String
  code          String   @unique
  address       String?
  contactPerson String?  @map("contact_person")
  email         String?
  phone         String?
  contactNo     String?
  gstin         String?  @unique
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  DyeingProgram DyeingProgram[]

  @@map("dyers")
}

model Compacter {
  id            Int      @id @default(autoincrement())
  name          String
  code          String   @unique
  address       String?
  contactPerson String?  @map("contact_person")
  email         String?
  phone         String?
  contactNo     String?
  gstin         String?  @unique
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("compacters")
}

model Colour {
  id          Int      @id @default(autoincrement())
  name        String
  code        String   @unique
  hexCode     String?  @map("hex_code")
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  YarnLot        YarnLot[]
  KnitterProgram KnitterProgram[]
  DyeingProgram  DyeingProgram[]

  @@map("colours")
}

model WashType {
  id          Int      @id @default(autoincrement())
  name        String
  code        String   @unique
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  DyeingProgram DyeingProgram[]

  @@map("wash_types")
}

model YarnQuality {
  id          Int      @id @default(autoincrement())
  name        String
  code        String   @unique
  composition String?
  count       String?
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  YarnLot        YarnLot[]
  KnitterProgram KnitterProgram[]

  @@map("yarn_qualities")
}

model YarnLot {
  id              Int      @id @default(autoincrement())
  hfCode          String   @map("hf_code")
  description     String?
  millId          Int      @map("mill_id")
  count           String?
  qualityId       Int?     @map("quality_id")
  numBags         Int      @map("num_bags")
  bagWeight       Float    @map("bag_weight")
  ratePerKg       Float    @map("rate_per_kg")
  totalWeight     Float    @map("total_weight")
  totalCost       Float    @map("total_cost")
  availableWeight Float    @map("available_weight")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  mill            Mill                @relation(fields: [millId], references: [id])
  quality         YarnQuality?        @relation(fields: [qualityId], references: [id])
  KnitterStock    KnitterStock[]
  DeliveryNoteItem DeliveryNoteItem[]
  // Keep colour relation if needed by existing code
  colourId        Int?                @map("colour_id")
  colour          Colour?             @relation(fields: [colourId], references: [id])

  @@map("yarn_lots")
}

model KnitterStock {
  id              Int      @id @default(autoincrement())
  knitterId       Int      @map("knitter_id")
  yarnLotId       Int      @map("yarn_lot_id")
  receivedWeight  Float    @map("received_weight")
  remainingWeight Float    @map("remaining_weight")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  knitter         Knitter        @relation(fields: [knitterId], references: [id])
  yarnLot         YarnLot        @relation(fields: [yarnLotId], references: [id])

  @@unique([knitterId, yarnLotId])
  @@map("knitter_stocks")
}

model DeliveryNote {
  id           Int                @id @default(autoincrement())
  dcNo         String             @unique @map("dc_no")
  transferDcNo String?            @map("transfer_dc_no")
  knitterId    Int                @map("knitter_id")
  deliveryDate DateTime           @map("delivery_date")
  remarks      String?
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  knitter      Knitter            @relation(fields: [knitterId], references: [id])
  items        DeliveryNoteItem[]

  @@map("delivery_notes")
}

model DeliveryNoteItem {
  id             Int          @id @default(autoincrement())
  deliveryNoteId Int          @map("delivery_note_id")
  yarnLotId      Int          @map("yarn_lot_id")
  sentWeight     Float        @map("sent_weight")
  cones          Int
  createdAt      DateTime     @default(now()) @map("created_at")

  deliveryNote   DeliveryNote @relation(fields: [deliveryNoteId], references: [id], onDelete: Cascade)
  yarnLot        YarnLot      @relation(fields: [yarnLotId], references: [id])

  @@map("delivery_note_items")
}

model KnitterProgram {
  id              Int             @id @default(autoincrement())
  programNo       String          @unique @map("program_no")
  memoNo          String?         @map("memo_no")
  knitterId       Int             @map("knitter_id")
  colourId        Int             @map("colour_id")
  yarnQualityId   Int             @map("yarn_quality_id")
  startDate       DateTime        @map("start_date")
  expectedEndDate DateTime?       @map("expected_end_date")
  status          String          @default("ACTIVE")
  remarks         String?
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  knitter         Knitter             @relation(fields: [knitterId], references: [id])
  colour          Colour              @relation(fields: [colourId], references: [id])
  yarnQuality     YarnQuality         @relation(fields: [yarnQualityId], references: [id])
  GreyFabricLot   GreyFabricLot[]

  @@map("knitter_programs")
}

model GreyFabricLot {
  id               Int            @id @default(autoincrement())
  lotNumber        String         @unique @map("lot_number")
  knitterProgramId Int            @map("knitter_program_id")
  receivedDate     DateTime       @map("received_date")
  grossWeight      Float          @map("gross_weight")
  netWeight        Float          @map("net_weight")
  rolls            Int
  remarks          String?
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  knitterProgram   KnitterProgram @relation(fields: [knitterProgramId], references: [id])
  DyeingProgram    DyeingProgram[]

  @@map("grey_fabric_lots")
}

model DyeingProgram {
  id             Int            @id @default(autoincrement())
  programNo      String         @unique @map("program_no")
  dyerId         Int            @map("dyer_id")
  colourId       Int            @map("colour_id")
  washTypeId     Int            @map("wash_type_id")
  greyFabricLotId Int           @map("grey_fabric_lot_id")
  startDate      DateTime       @map("start_date")
  status         String         @default("ACTIVE")
  remarks        String?
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  dyer           Dyer           @relation(fields: [dyerId], references: [id])
  colour         Colour         @relation(fields: [colourId], references: [id])
  washType       WashType       @relation(fields: [washTypeId], references: [id])
  greyFabricLot  GreyFabricLot  @relation(fields: [greyFabricLotId], references: [id])

  @@map("dyeing_programs")
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  tableName   String   @map("table_name")
  recordId    String   @map("record_id")
  action      Action
  oldData     Json?    @map("old_data")
  newData     Json?    @map("new_data")
  performedBy String   @map("performed_by")
  performedAt DateTime @default(now()) @map("performed_at")

  @@index([tableName, recordId])
  @@index([performedAt])
  @@map("audit_logs")
}

enum Action {
  CREATE
  UPDATE
  DELETE
}
