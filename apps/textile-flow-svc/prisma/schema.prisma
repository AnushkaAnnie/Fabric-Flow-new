generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Mill {
  id           Int          @id @default(autoincrement())
  name         String
  addressLine1 String?      @map("address_line1")
  addressLine2 String?      @map("address_line2")
  city         String?
  state        String?
  pincode      String?
  email        String?
  phone        String?
  gstin        String?      @unique
  isActive     Boolean      @default(true) @map("is_active")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  YarnLot      YarnLot[]
  yarnInwards  YarnInward[]

  @@map("mills")
}

model Knitter {
  id                 Int              @id @default(autoincrement())
  name               String
  addressLine1       String?          @map("address_line1")
  addressLine2       String?          @map("address_line2")
  city               String?
  state              String?
  pincode            String?
  email              String?
  phone              String?
  gstin              String?          @unique
  isActive           Boolean          @default(true) @map("is_active")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")
  DeliveryNoteSource DeliveryNote[]   @relation("SourceKnitter")
  DeliveryNoteDest   DeliveryNote[]   @relation("DestKnitter")
  KnitterProgram     KnitterProgram[]
  KnitterStock       KnitterStock[]
  memoLines          MemoLine[]
  yarnInwards        YarnInward[]
  greyFabricLots     GreyFabricLot[]

  @@map("knitters")
}

model Dyer {
  id            Int             @id @default(autoincrement())
  name          String
  addressLine1  String?         @map("address_line1")
  addressLine2  String?         @map("address_line2")
  city          String?
  state         String?
  pincode       String?
  email         String?
  phone         String?
  gstin         String?         @unique
  isActive      Boolean         @default(true) @map("is_active")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  DyeingProgram     DyeingProgram[]
  memoLines         MemoLine[]
  knitterPrograms   KnitterProgram[]
  dyeingDispatches  DyeingDispatch[]

  @@map("dyers")
}

model Compacter {
  id           Int      @id @default(autoincrement())
  name         String
  addressLine1 String?  @map("address_line1")
  addressLine2 String?  @map("address_line2")
  city         String?
  state        String?
  pincode      String?
  email        String?
  phone        String?
  gstin        String?  @unique
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("compacters")
}

model Colour {
  id             Int              @id @default(autoincrement())
  name           String
  code           String           @unique
  hexCode        String?          @map("hex_code")
  description    String?
  isActive       Boolean          @default(true) @map("is_active")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  DyeingProgram  DyeingProgram[]
  YarnLot        YarnLot[]

  @@map("colours")
}

model WashType {
  id            Int             @id @default(autoincrement())
  name          String
  code          String          @unique
  description   String?
  isActive      Boolean         @default(true) @map("is_active")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  DyeingProgram DyeingProgram[]

  @@map("wash_types")
}

model YarnLot {
  id              Int      @id @default(autoincrement())
  hfCode          String   @map("hf_code")
  description     String?
  millId          Int      @map("mill_id")
  count           String?
  ratePerKg       Float    @map("rate_per_kg")
  totalWeight     Float    @map("total_weight")
  totalCost       Float    @map("total_cost")
  availableWeight Float    @map("available_weight")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  colourId        Int?     @map("colour_id")

  knitterStocks  KnitterStock[]
  colour        Colour?        @relation(fields: [colourId], references: [id])
  mill          Mill           @relation(fields: [millId], references: [id])
  yarnInwardId  Int?           @map("yarn_inward_id")
  yarnInward    YarnInward?    @relation(fields: [yarnInwardId], references: [id])
  memoLines       MemoLine[]
  deliveryNotes   DeliveryNote[]
  knitterPrograms KnitterProgram[]

  @@map("yarn_lots")
}

model KnitterStock {
  id              Int      @id @default(autoincrement())
  knitterId       Int      @map("knitter_id")
  yarnLotId       Int      @map("yarn_lot_id")
  receivedWeight  Float    @map("received_weight")
  remainingWeight Float    @map("remaining_weight")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  knitter         Knitter  @relation(fields: [knitterId], references: [id])
  yarnLot         YarnLot  @relation(fields: [yarnLotId], references: [id])

  @@unique([knitterId, yarnLotId])
  @@map("knitter_stocks")
}

model DeliveryNote {
  id                   Int      @id @default(autoincrement())
  sourceKnitterId      Int      @map("source_knitter_id")
  sourceKnitter        Knitter  @relation("SourceKnitter", fields: [sourceKnitterId], references: [id])
  destinationKnitterId Int      @map("destination_knitter_id")
  destinationKnitter   Knitter  @relation("DestKnitter", fields: [destinationKnitterId], references: [id])
  yarnLotId            Int      @map("yarn_lot_id")
  yarnLot              YarnLot  @relation(fields: [yarnLotId], references: [id])
  quantity             Decimal  @db.Decimal(10, 2)
  dcNumber             String?  @map("dc_number")
  note                 String?
  createdAt            DateTime @default(now()) @map("created_at")

  @@map("delivery_notes")
}

model KnitterProgram {
  id            Int       @id @default(autoincrement())
  knitterId     Int
  knitter       Knitter   @relation(fields: [knitterId], references: [id])
  yarnLotId     Int
  yarnLot       YarnLot   @relation(fields: [yarnLotId], references: [id])
  quantityUsed  Decimal   @db.Decimal(10,2)   // kg of yarn consumed
  greyWeight    Decimal   @db.Decimal(10,2)   // actual scale weight of grey fabric produced
  numRolls      Int?
  dia           String?
  gg            String?
  loopLength    String?
  fabricName    String?
  fabricColour  String?
  programmeRef  String?
  preAssignedDyerId Int?
  preAssignedDyer   Dyer?   @relation(fields: [preAssignedDyerId], references: [id])
  anomalyFlag   Boolean   @default(false)    // set to true if greyWeight > quantityUsed
  programDate   DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  greyFabricLots GreyFabricLot[]
}

enum GreyFabricLotSource {
  KNITTED
  PURCHASED
}

enum GreyFabricLotStatus {
  AVAILABLE
  DISPATCHED
  CONSUMED
  DELETED
}

model GreyFabricLot {
  id              Int             @id @default(autoincrement())
  lotNumber       String          @unique
  knitterProgramId Int?
  knitterProgram  KnitterProgram? @relation(fields: [knitterProgramId], references: [id])
  knitterId       Int?
  knitter         Knitter?        @relation(fields: [knitterId], references: [id])
  greyWeight      Decimal         @db.Decimal(10,2)
  rollCount       Int?
  source          GreyFabricLotSource @default(KNITTED)
  status          GreyFabricLotStatus @default(AVAILABLE)
  greyFabricInwardId Int?
  greyFabricInward GreyFabricInward? @relation(fields: [greyFabricInwardId], references: [id])
  dyeingDispatchLines DyeingDispatchLine[]
  DyeingProgram      DyeingProgram[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model DyeingDispatch {
  id            Int       @id @default(autoincrement())
  dispatchDate  DateTime  @default(now())
  dyerId        Int
  dyer          Dyer      @relation(fields: [dyerId], references: [id])
  remarks       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lines         DyeingDispatchLine[]
}

model DyeingDispatchLine {
  id              Int             @id @default(autoincrement())
  dispatchId      Int
  dispatch        DyeingDispatch  @relation(fields: [dispatchId], references: [id])
  greyFabricLotId Int
  greyFabricLot   GreyFabricLot   @relation(fields: [greyFabricLotId], references: [id])
  sentWeight      Decimal         @db.Decimal(10,2)       // weight sent (grey lot weight)
  receivedWeight  Decimal?        @db.Decimal(10,2)       // actual received from dyer
  receivedDate    DateTime?
  processLossPercent Decimal?     @db.Decimal(5,2)
  status          DyeingStatus    @default(DISPATCHED)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([greyFabricLotId])   // a grey lot can be in only one active dispatch
}

enum DyeingStatus {
  DISPATCHED
  RECEIVED
  CANCELLED
}

model DyeingProgram {
  id              Int           @id @default(autoincrement())
  programNo       String        @unique @map("program_no")
  dyerId          Int           @map("dyer_id")
  colourId        Int           @map("colour_id")
  washTypeId      Int           @map("wash_type_id")
  greyFabricLotId Int           @map("grey_fabric_lot_id")
  startDate       DateTime      @map("start_date")
  status          String        @default("ACTIVE")
  remarks         String?
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  colour          Colour        @relation(fields: [colourId], references: [id])
  dyer            Dyer          @relation(fields: [dyerId], references: [id])
  greyFabricLot   GreyFabricLot @relation(fields: [greyFabricLotId], references: [id])
  washType        WashType      @relation(fields: [washTypeId], references: [id])

  @@map("dyeing_programs")
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  tableName   String   @map("table_name")
  recordId    String   @map("record_id")
  action      Action
  oldData     Json?    @map("old_data")
  newData     Json?    @map("new_data")
  performedBy String   @map("performed_by")
  performedAt DateTime @default(now()) @map("performed_at")

  @@index([tableName, recordId])
  @@index([performedAt])
  @@map("audit_logs")
}

enum Action {
  CREATE
  UPDATE
  DELETE
}

// ---- Yarn Inward (purchase receipt) ----
model YarnInward {
  id                Int       @id @default(autoincrement())
  receiptDate       DateTime  @default(now()) @map("receipt_date")
  millId            Int       @map("mill_id")
  mill              Mill      @relation(fields: [millId], references: [id])
  deliveryKnitterId Int       @map("delivery_knitter_id")
  deliveryKnitter   Knitter   @relation(fields: [deliveryKnitterId], references: [id])
  hfBatch           String?   @map("hf_batch")
  yarnCount         String?   @map("yarn_count")
  yarnQuality       String?   @map("yarn_quality")
  rlVl              String?   @map("rl_vl")                         // "RL" or "VL"
  numBags           Int?      @map("num_bags")
  bagWeight         Decimal?  @map("bag_weight") @db.Decimal(10, 2) // default 60 in application
  totalWeight       Decimal   @map("total_weight") @db.Decimal(10, 2) // computed: numBags * bagWeight
  ratePerKg         Decimal?  @map("rate_per_kg") @db.Decimal(10, 2)
  cgstRate          Decimal?  @map("cgst_rate") @db.Decimal(5, 2)   // default 2.5
  sgstRate          Decimal?  @map("sgst_rate") @db.Decimal(5, 2)   // default 2.5
  cgstAmount        Decimal?  @map("cgst_amount") @db.Decimal(10, 2)
  sgstAmount        Decimal?  @map("sgst_amount") @db.Decimal(10, 2)
  totalCost         Decimal?  @map("total_cost") @db.Decimal(10, 2) // taxable + taxes
  purchaseAccount   String?   @map("purchase_account")
  remarks           String?
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  yarnLots          YarnLot[]

  @@map("yarn_inwards")
}

// ---- Memo (knitter dispatch document) ----
model Memo {
  id           Int        @id @default(autoincrement())
  memoNo       Int        @unique @map("memo_no")
  issueDate    DateTime   @default(now()) @map("issue_date")
  programmeRef String?    @map("programme_ref")
  account      String?
  remarks      String?
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  lines        MemoLine[]

  @@map("memos")
}

model MemoLine {
  id                Int      @id @default(autoincrement())
  memoId            Int      @map("memo_id")
  memo              Memo     @relation(fields: [memoId], references: [id])
  yarnLotId         Int      @map("yarn_lot_id")
  yarnLot           YarnLot  @relation(fields: [yarnLotId], references: [id])
  knitterId         Int      @map("knitter_id")
  knitter           Knitter  @relation(fields: [knitterId], references: [id])
  yarnCount         String?  @map("yarn_count")
  dia               String?
  gg                String?
  loopLength        String?  @map("loop_length")
  fabricName        String?  @map("fabric_name")
  fabricColour      String?  @map("fabric_colour")
  expectedRolls     Int?     @map("expected_rolls")
  preAssignedDyerId Int?     @map("pre_assigned_dyer_id")
  dyer              Dyer?    @relation(fields: [preAssignedDyerId], references: [id])
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("memo_lines")
}

// ---- Grey Fabric Inward (External Purchase) ----
model GreyFabricInward {
  id              Int             @id @default(autoincrement())
  receiptDate     DateTime        @default(now()) @map("receipt_date")
  supplierName    String          @map("supplier_name")
  fabricType      String?         @map("fabric_type")
  colour          String?
  totalWeight     Decimal         @map("total_weight") @db.Decimal(10, 2)
  rollCount       Int?            @map("roll_count")
  ratePerKg       Decimal?        @map("rate_per_kg") @db.Decimal(10, 2)
  totalCost       Decimal?        @map("total_cost") @db.Decimal(10, 2)
  purchaseAccount String?         @map("purchase_account")
  remarks         String?
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  greyFabricLots  GreyFabricLot[]

  @@map("grey_fabric_inwards")
}
